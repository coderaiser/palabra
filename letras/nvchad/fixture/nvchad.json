[
    "mkdir -p ~/.local/bin",
    "wget -c https://github.com/neovim/neovim/releases/download/v0.12.3/nvim-linux-$(uname -m).tar.gz -O ${XDG_CACHE_HOME:-/tmp}/nvim-linux-$(uname -m).tar.gz",
    "rm -rf ~/.local/share/nvim",
    "mkdir -p ~/.local/share/nvim",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/nvim-linux-$(uname -m).tar.gz -C ~/.local/share",
    "rm ${XDG_CACHE_HOME:-/tmp}/nvim-linux-$(uname -m).tar.gz",
    "ln -fs ~/.local/share/nvim/bin/nvim ~/.local/bin/nvim",
    "[ -e ~/.local/share/nvim-linux-$(uname -m) ] && rm -rf ~/.local/share/nvim || true",
    "[ -e ~/.local/share/nvim-linux-$(uname -m) ] && mv -f ~/.local/share/nvim-linux-$(uname -m) ~/.local/share/nvim || true",
    "nvim -v",
    "rm -rf ${XDG_CONFIG_HOME:-~/.config}/nvim",
    "git clone https://github.com/NvChad/starter ${XDG_CONFIG_HOME:-~/.config}/nvim",
    "nvim --headless '+Lazy! sync' +qa",
    "ln -fs ~/.local/share/nvchad/bin/nvchad ~/.local/bin/nvchad"
]