{
    "name": "k3d",
    "version": "5.9.0",
    "bin": "{{ name }}",
    "executable": true,
    "test": [
        "{{ name }} -v"
    ],
    "alias": {
        "arch": {
            "x64": "amd64"
        }
    },
    "url": {
        "darwin": "https://github.com/k3d-io/k3d/releases/download/v{{ version }}/k3d-darwin-{{ arch }}",
        "linux": "https://github.com/k3d-io/k3d/releases/download/v{{ version }}/k3d-linux-{{ arch }}"
    },
    "rename": "{{ name }}-{{ platform }}-{{ arch }}"
}
