{
    "name": "k3d",
    "version": "5.9.0",
    "bin": "{{ name }}",
    "executable": true,
    "preparado": true,
    "test": [
        "{{ name }} --version"
    ],
    "alias": {
        "arch": {
            "x64": "amd64"
        }
    },
    "url": "https://github.com/k3d-io/k3d/releases/download/v{{ version }}/{{ name }}-{{ platform }}-{{ arch }}",
    "rename": "{{ name }}-{{ platform }}-{{ arch }}"
}
