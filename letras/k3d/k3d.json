{
    "name": "k3d",
    "url": "https://raw.githubusercontent.com/k3d-io/k3d/main/install.sh",
    "bin": "{{ name }}",
    "env": {
        "K3D_INSTALL_DIR": "{{ directorio }}/k3d",
        "USE_SUDO": "false"
    },
    "test": [
        "{{ name }} -v"
    ],
    "commands": [
        "mkdir -p {{ directorio }}/{{ name }}"
    ]
}
