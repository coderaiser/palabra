[
    "mkdir -p ~/.local/bin",
    "mkdir -p ~/.local/share/k3d",
    "wget https://github.com/k3d-io/k3d/releases/download/v5.9.0/k3d-linux-arm64 -O ~/.local/share/k3d/k3d",
    "ln -fs ~/.local/share/k3d/k3d ~/.local/bin/k3d",
    "[ -e ~/.local/share/k3d-linux-arm64 ] && rm -rf ~/.local/share/k3d || true",
    "[ -e ~/.local/share/k3d-linux-arm64 ] && mv -f ~/.local/share/k3d-linux-arm64 ~/.local/share/k3d || true",
    "chmod +x ~/.local/share/k3d/k3d",
    "k3d -v"
]