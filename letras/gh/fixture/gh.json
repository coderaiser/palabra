[
    "mkdir -p ~/.local/bin",
    "wget -c https://github.com/cli/cli/releases/download/v2.95.0/gh_2.95.0_linux_arm64.tar.gz -O ${XDG_CACHE_HOME:-/tmp}/gh_2.95.0_linux_arm64.tar.gz",
    "rm -rf ~/.local/share/gh",
    "mkdir -p ~/.local/share/gh",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/gh_2.95.0_linux_arm64.tar.gz -C ~/.local/share",
    "rm ${XDG_CACHE_HOME:-/tmp}/gh_2.95.0_linux_arm64.tar.gz",
    "ln -fs ~/.local/share/gh/bin/gh ~/.local/bin/gh",
    "[ -e ~/.local/share/gh_2.95.0_macOS_arm64 ] && rm -rf ~/.local/share/gh || true",
    "[ -e ~/.local/share/gh_2.95.0_macOS_arm64 ] && mv -f ~/.local/share/gh_2.95.0_macOS_arm64 ~/.local/share/gh || true",
    "[ -e ~/.local/share/gh_2.95.0_linux_arm64 ] && rm -rf ~/.local/share/gh || true",
    "[ -e ~/.local/share/gh_2.95.0_linux_arm64 ] && mv -f ~/.local/share/gh_2.95.0_linux_arm64 ~/.local/share/gh || true",
    "gh version"
]