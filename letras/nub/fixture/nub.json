[
    "mkdir -p ~/.local/bin",
    "wget -c https://github.com/nubjs/nub/releases/download/0.4.13/nub-linux-arm64.tar.gz -O ${XDG_CACHE_HOME:-/tmp}/nub-linux-arm64.tar.gz",
    "rm -rf ~/.local/share/nub",
    "mkdir -p ~/.local/share/nub",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/nub-linux-arm64.tar.gz -C ~/.local/share",
    "rm ${XDG_CACHE_HOME:-/tmp}/nub-linux-arm64.tar.gz",
    "ln -fs ~/.local/share/nub ~/.local/bin/nub",
    "nub --version"
]