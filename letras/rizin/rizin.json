{
    "name": "rizin",
    "version": "0.8.2",
    "url": "https://github.com/rizinorg/rizin/releases/download/v{{ version }}/rizin-v{{ version }}-static-x86_64.tar.xz",
    "extractDirectory": "{{ directorio }}/{{ name }}",
    "bin": {
        "rizin": "bin/rizin",
        "rz-asm": "bin/rz-asm",
        "rz-ax": "bin/rz-ax",
        "rz-bin": "bin/rz-bin",
        "rz-diff": "bin/rz-diff",
        "rz-find": "bin/rz-find",
        "rz-gg": "bin/rz-gg",
        "rz-hash": "bin/rz-hash",
        "rz-run": "bin/rz-run",
        "rz-sign": "bin/rz-sign",
        "rz-test": "bin/rz-test"
    },
    "test": [
        "rizin -v",
        "rz-asm -v",
        "rz-ax -v",
        "rz-bin -v",
        "rz-diff -v",
        "rz-find -v",
        "rz-gg -v",
        "rz-hash -v",
        "rz-run -v",
        "rz-sign -v",
        "rz-test -v"
    ]
}
