{
    "name": "rizin",
    "version": "0.9.0",
    "url": "https://github.com/coderaiser/palabra/releases/download/v2.19.2/rizin-v{{ version }}-linux-{{ arch }}.tar.xz",
    "extractDirectory": "{{ directorio }}/{{ name }}",
    "bin": {
        "rizin": "bin/rizin",
        "rz-asm": "bin/rz-asm",
        "rz-ax": "bin/rz-ax",
        "rz-bin": "bin/rz-bin",
        "rz-diff": "bin/rz-diff",
        "rz-find": "bin/rz-find",
        "rz-gg": "bin/rz-gg",
        "rz-hash": "bin/rz-hash",
        "rz-run": "bin/rz-run",
        "rz-sign": "bin/rz-sign",
        "rz-test": "bin/rz-test"
    },
    "test": [
        "rizin -v",
        "rz-asm -v",
        "rz-ax -v",
        "rz-bin -v",
        "rz-find -v",
        "rz-gg -v",
        "rz-hash -v",
        "rz-run -v",
        "rz-sign -v",
        "rz-test -v"
    ],
    "alias": {
        "arch": {
            "x64": "amd64",
            "arm64": "aarch64"
        }
    }
}
