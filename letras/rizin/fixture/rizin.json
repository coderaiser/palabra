[
    "mkdir -p ~/.local/bin",
    "wget -c -nc https://github.com/rizinorg/rizin/releases/download/v0.8.2/rizin-v0.8.2-static-x86_64.tar.xz -O /tmp/rizin-v0.8.2-static-x86_64.tar.xz",
    "rm -rf ~/.local/src/rizin",
    "mkdir -p ~/.local/src/rizin",
    "tar xf /tmp/rizin-v0.8.2-static-x86_64.tar.xz -C ~/.local/src/rizin",
    "rm /tmp/rizin-v0.8.2-static-x86_64.tar.xz",
    "ln -fs ~/.local/src/rizin/bin/rizin ~/.local/bin/rizin",
    "ln -fs ~/.local/src/rizin/bin/rz-asm ~/.local/bin/rz-asm",
    "ln -fs ~/.local/src/rizin/bin/rz-ax ~/.local/bin/rz-ax",
    "ln -fs ~/.local/src/rizin/bin/rz-bin ~/.local/bin/rz-bin",
    "ln -fs ~/.local/src/rizin/bin/rz-diff ~/.local/bin/rz-diff",
    "ln -fs ~/.local/src/rizin/bin/rz-find ~/.local/bin/rz-find",
    "ln -fs ~/.local/src/rizin/bin/rz-gg ~/.local/bin/rz-gg",
    "ln -fs ~/.local/src/rizin/bin/rz-hash ~/.local/bin/rz-hash",
    "ln -fs ~/.local/src/rizin/bin/rz-run ~/.local/bin/rz-run",
    "ln -fs ~/.local/src/rizin/bin/rz-sign ~/.local/bin/rz-sign",
    "ln -fs ~/.local/src/rizin/bin/rz-test ~/.local/bin/rz-test"
]