[
    "mkdir -p ~/.local/bin",
    "wget -c https://github.com/rizinorg/rizin/releases/download/v0.8.2/rizin-v0.8.2-static-x86_64.tar.xz -O ${XDG_CACHE_HOME:-/tmp}/rizin-v0.8.2-static-x86_64.tar.xz",
    "rm -rf ~/.local/share/rizin",
    "mkdir -p ~/.local/share/rizin",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/rizin-v0.8.2-static-x86_64.tar.xz -C ~/.local/share/rizin",
    "rm ${XDG_CACHE_HOME:-/tmp}/rizin-v0.8.2-static-x86_64.tar.xz",
    "ln -fs ~/.local/share/rizin/bin/rizin ~/.local/bin/rizin",
    "ln -fs ~/.local/share/rizin/bin/rz-asm ~/.local/bin/rz-asm",
    "ln -fs ~/.local/share/rizin/bin/rz-ax ~/.local/bin/rz-ax",
    "ln -fs ~/.local/share/rizin/bin/rz-bin ~/.local/bin/rz-bin",
    "ln -fs ~/.local/share/rizin/bin/rz-diff ~/.local/bin/rz-diff",
    "ln -fs ~/.local/share/rizin/bin/rz-find ~/.local/bin/rz-find",
    "ln -fs ~/.local/share/rizin/bin/rz-gg ~/.local/bin/rz-gg",
    "ln -fs ~/.local/share/rizin/bin/rz-hash ~/.local/bin/rz-hash",
    "ln -fs ~/.local/share/rizin/bin/rz-run ~/.local/bin/rz-run",
    "ln -fs ~/.local/share/rizin/bin/rz-sign ~/.local/bin/rz-sign",
    "ln -fs ~/.local/share/rizin/bin/rz-test ~/.local/bin/rz-test",
    "rizin -v",
    "rz-asm -v",
    "rz-ax -v",
    "rz-bin -v",
    "rz-find -v",
    "rz-gg -v",
    "rz-hash -v",
    "rz-run -v",
    "rz-sign -v",
    "rz-test -v"
]