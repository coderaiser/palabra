{
    "name": "shellcheck",
    "version": "0.11.0",
    "url": "https://github.com/koalaman/shellcheck/releases/download/v{{ version }}/shellcheck-v{{ version }}.{{ platform }}.{{ arch }}.tar.xz",
    "bin": "{{ name }}",
    "test": "{{ name }} --version",
    "rename": "shellcheck-v{{ version }}",
    "alias": {
        "arch": {
            "x64": "x86_64",
            "arm64": "aarch64"
        }
    }
}
