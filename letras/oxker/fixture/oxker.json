[
    "mkdir -p ~/.local/bin",
    "wget -c https://github.com/mrjackwills/oxker/releases/download/v0.13.1/oxker_linux_x86_64.tar.gz -O ${XDG_CACHE_HOME:-/tmp}/oxker_linux_x86_64.tar.gz",
    "rm -rf ~/.local/share/oxker",
    "mkdir -p ~/.local/share/oxker",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/oxker_linux_x86_64.tar.gz -C ~/.local/share",
    "rm ${XDG_CACHE_HOME:-/tmp}/oxker_linux_x86_64.tar.gz",
    "ln -fs ~/.local/share/oxker ~/.local/bin/oxker",
    "oxker --version"
]