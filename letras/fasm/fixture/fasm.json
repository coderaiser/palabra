[
    "mkdir -p ~/.local/bin",
    "wget -c https://flatassembler.net/fasm-1.73.32.tgz -O ${XDG_CACHE_HOME:-/tmp}/fasm-1.73.32.tgz",
    "rm -rf ~/.local/share/fasm",
    "mkdir -p ~/.local/share/fasm",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/fasm-1.73.32.tgz -C ~/.local/share",
    "rm ${XDG_CACHE_HOME:-/tmp}/fasm-1.73.32.tgz",
    "ln -fs ~/.local/share/fasm/fasm.x64 ~/.local/bin/fasm",
    "fasm ~/.local/share/fasm/examples/elfexe/hello64.asm"
]