[
    "mkdir -p ~/.local/bin",
    "wget -c https://github.com/erans/pgsqlite/releases/download/v0.0.22/pgsqlite-linux-arm64.tar.gz -O ${XDG_CACHE_HOME:-/tmp}/pgsqlite-linux-arm64.tar.gz",
    "rm -rf ~/.local/share/pgsqlite",
    "mkdir -p ~/.local/share/pgsqlite",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/pgsqlite-linux-arm64.tar.gz -C ~/.local/share",
    "rm ${XDG_CACHE_HOME:-/tmp}/pgsqlite-linux-arm64.tar.gz",
    "ln -fs ~/.local/share/pgsqlite ~/.local/bin/pgsqlite",
    "pgsqlite --version"
]