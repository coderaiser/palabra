{
    "name": "kustomize",
    "version": "5.8.1",
    "bin": "{{ name }}",
    "executable": true,
    "preparado": true,
    "test": [
        "{{ name }} version"
    ],
    "alias": {
        "arch": {
            "x64": "amd64"
        }
    },
    "url": "https://github.com/kubernetes-sigs/kustomize/releases/download/kustomize%2Fv{{ version }}/kustomize_v{{ version }}_{{ platform }}_{{ arch }}.tar.gz"
}
