[
    "mkdir -p ~/.local/bin",
    "mkdir -p ~/.local/share/kustomize",
    "wget https://github.com/kubernetes-sigs/kustomize/releases/download/kustomize%2Fv5.8.1/kustomize_v5.8.1_linux_arm64.tar.gz -O ~/.local/share/kustomize/kustomize",
    "ln -fs ~/.local/share/kustomize/kustomize ~/.local/bin/kustomize",
    "chmod +x ~/.local/share/kustomize/kustomize",
    "kustomize version"
]