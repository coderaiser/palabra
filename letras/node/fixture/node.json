[
    "mkdir -p ~/.local/bin",
    "NVM_DIR=~/.local/share/nvm mkdir -p ~/.local/share/nvm",
    "NVM_DIR=~/.local/share/nvm bash -c \"$(curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh)\"",
    "NVM_DIR=~/.local/share/nvm sed -i.bak 's/nvm_die_on_prefix() {/nvm_die_on_prefix() { return;/' ~/.local/share/nvm/nvm.sh",
    "NVM_DIR=~/.local/share/nvm rm ~/.local/share/nvm/nvm.sh.bak",
    "NVM_DIR=~/.local/share/nvm . ~/.local/share/nvm/nvm.sh",
    "NVM_DIR=~/.local/share/nvm . ~/.local/share/nvm/nvm.sh",
    "NVM_DIR=~/.local/share/nvm nvm -v",
    ". ~/.local/share/nvm/nvm.sh",
    "nvm i node",
    "ln -fs ${NVM_DIR}/versions/node/$(node -v) ~/.local/share/node",
    "ln -fs ~/.local/share/node/bin/node ~/.local/bin/node",
    "node -v"
]