[
    "mkdir -p ~/.local/bin",
    "wget -c -nc https://go.dev/dl/go1.21.2.linux-amd64.tar.gz -O ${XDG_CACHE_HOME:-/tmp}/go1.21.2.linux-amd64.tar.gz",
    "rm -rf ~/.local/src/go",
    "mkdir -p ~/.local/src/go",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/go1.21.2.linux-amd64.tar.gz -C ~/.local/src",
    "rm ${XDG_CACHE_HOME:-/tmp}/go1.21.2.linux-amd64.tar.gz",
    "ln -fs ~/.local/src/go/bin/go ~/.local/bin/go",
    "ln -fs ~/.local/src/go/bin/gofmt ~/.local/bin/gofmt",
    "go version"
]