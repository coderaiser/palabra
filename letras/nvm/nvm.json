{
    "name": "nvm",
    "version": "0.40.4",
    "url": "https://raw.githubusercontent.com/nvm-sh/nvm/v{{ version }}/install.sh",
    "env": {
        "NVM_DIR": "{{ directorio }}/nvm"
    },
    "bin": {},
    "beforeInstall": [
        "mkdir -p {{ directorio }}/nvm"
    ],
    "afterInstall": [
        "sed -i.bak 's/nvm_die_on_prefix() {/nvm_die_on_prefix() { return;/' {{ directorio }}/nvm/nvm.sh",
        "rm {{ directorio }}/nvm/nvm.sh.bak"
    ]
}
