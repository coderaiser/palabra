{
    "name": "haskell",
    "url": "https://get-ghcup.haskell.org",
    "env": {
        "BOOTSTRAP_HASKELL_NONINTERACTIVE": "1"
    },
    "execute": true,
    "hogar": "ghcup",
    "bin": {
        "cabal": "bin/cabal",
        "ghcup": "bin/ghcup",
        "stack": "bin/stack",
        "ghc": "bin/ghc"
    },
    "test": [
        "ghcup --version",
        "cabal --version",
        "ghc --version",
        "stack --version"
    ],
    "commands": [
        "mv ~/.ghcup {{ directorio }}/ghcup",
        "ln -fs {{ directorio }}/ghcup/ghc/{{ version }}/lib/ghc-{{ version }}/bin/ghc {{ directorio }}/../bin/ghc"
    ]
}
