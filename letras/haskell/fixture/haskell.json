[
    "mkdir -p ~/.local/bin",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 bash -c \"$(curl -fsSL https://get-ghcup.haskell.org)\"",
    "ln -fs ~/.local/share/ghcup/bin/cabal ~/.local/bin/cabal",
    "ln -fs ~/.local/share/ghcup/bin/ghcup ~/.local/bin/ghcup",
    "ln -fs ~/.local/share/ghcup/bin/stack ~/.local/bin/stack",
    "ln -fs ~/.local/share/ghcup/bin/ghc ~/.local/bin/ghc",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 mv ~/.ghcup ~/.local/share/ghcup",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 ln -fs ~/.local/share/ghcup/ghc/undefined/lib/ghc-undefined/bin/ghc ~/.local/share/../bin/ghc",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 ghcup --version",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 cabal --version",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 ghc --version",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 stack --version"
]