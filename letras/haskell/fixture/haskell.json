[
    "mkdir -p ~/.local/bin",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 BOOTSTRAP_HASKELL_GHC_VERSION=9.6.7 bash -c \"$(curl -fsSL https://get-ghcup.haskell.org)\"",
    "ln -fs ~/.local/share/ghcup/bin/cabal ~/.local/bin/cabal",
    "ln -fs ~/.local/share/ghcup/bin/ghcup ~/.local/bin/ghcup",
    "ln -fs ~/.local/share/ghcup/bin/stack ~/.local/bin/stack",
    "ln -fs ~/.local/share/ghcup/bin/ghc ~/.local/bin/ghc",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 BOOTSTRAP_HASKELL_GHC_VERSION=9.6.7 mv ~/.ghcup ~/.local/share/ghcup",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 BOOTSTRAP_HASKELL_GHC_VERSION=9.6.7 ln -fs ~/.local/share/ghcup/ghc/9.6.7/lib/ghc-9.6.7/bin/ghc ~/.local/share/../bin/ghc",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 BOOTSTRAP_HASKELL_GHC_VERSION=9.6.7 ghcup --version",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 BOOTSTRAP_HASKELL_GHC_VERSION=9.6.7 cabal --version",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 BOOTSTRAP_HASKELL_GHC_VERSION=9.6.7 ghc --version",
    "BOOTSTRAP_HASKELL_NONINTERACTIVE=1 BOOTSTRAP_HASKELL_GHC_VERSION=9.6.7 stack --version"
]