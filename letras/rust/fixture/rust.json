    "ln -fs ~/.local/share/cargo/bin/rls ~/.local/bin/rls",
    "ln -fs ~/.local/share/cargo/bin/rust-gdb ~/.local/bin/rust-gdb",
    "ln -fs ~/.local/share/cargo/bin/rust-lldb ~/.local/bin/rust-lldb",
    "ln -fs ~/.local/share/cargo/bin/rustc ~/.local/bin/rustc",
