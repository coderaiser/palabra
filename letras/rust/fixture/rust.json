[
    "mkdir -p ~/.local/bin",
    "RUSTUP_HOME=~/.local/src/rustup CARGO_HOME=~/.local/src/cargo bash -c \"$(curl -fsSL https://sh.rustup.rs)\" -- -y",
    "ln -fs ~/.local/src/cargo/bin/cargo ~/.local/bin/cargo",
    "ln -fs ~/.local/src/cargo/bin/cargo-clippy ~/.local/bin/cargo-clippy",
    "ln -fs ~/.local/src/cargo/bin/cargo-fmt ~/.local/bin/cargo-fmt",
    "ln -fs ~/.local/src/cargo/bin/cargo-miri ~/.local/bin/cargo-miri",
    "ln -fs ~/.local/src/cargo/bin/clippy-driver ~/.local/bin/clippy-driver",
    "ln -fs ~/.local/src/cargo/bin/rls ~/.local/bin/rls",
    "ln -fs ~/.local/src/cargo/bin/rust-gdb ~/.local/bin/rust-gdb",
    "ln -fs ~/.local/src/cargo/bin/rust-lldb ~/.local/bin/rust-lldb",
    "ln -fs ~/.local/src/cargo/bin/rustc ~/.local/bin/rustc",
    "ln -fs ~/.local/src/cargo/bin/rustdoc ~/.local/bin/rustdoc",
    "ln -fs ~/.local/src/cargo/bin/rustfmt ~/.local/bin/rustfmt",
    "ln -fs ~/.local/src/cargo/bin/rustup ~/.local/bin/rustup",
    "RUSTUP_HOME=~/.local/src/rustup CARGO_HOME=~/.local/src/cargo rustup default stable",
    "cargo --version",
    "rustfmt --version",
    "cargo-clippy --version",
    "cargo-fmt --version",
    "cargo-miri --version",
    "clippy-driver --version",
    "rust-gdb --version",
    "rustc --version",
    "rustdoc --version",
    "rustfmt --version"
]