{
    "name": "rust",
    "url": "https://sh.rustup.rs",
    "confirmar": false,
    "bin": {
        "cargo": "bin/cargo",
        "cargo-clippy": "bin/cargo-clippy",
        "cargo-fmt": "bin/cargo-fmt",
        "cargo-miri": "bin/cargo-miri",
        "clippy-driver": "bin/clippy-driver",
        "rls": "bin/rls",
        "rust-gdb": "bin/rust-gdb",
        "rust-lldb": "bin/rust-lldb",
        "rustc": "bin/rustc",
        "rustdoc": "bin/rustdoc",
        "rustfmt": "bin/rustfmt",
        "rustup": "bin/rustup"
    },
    "hogar": "cargo",
    "test": [
        "cargo --version",
        "rustfmt --version",
        "cargo-clippy --version",
        "cargo-fmt --version",
        "cargo-miri --version",
        "clippy-driver --version",
        "rust-gdb --version",
        "rustc --version",
        "rustdoc --version",
        "rustfmt --version",
        "rustup show"
    ],
    "env": {
        "RUSTUP_HOME": "{{ directorio }}/rustup",
        "CARGO_HOME": "{{ directorio }}/cargo"
    },
    "commands": [
        "rustup default stable"
    ]
}
