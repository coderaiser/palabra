{
    "name": "gdu",
    "version": "5.35.0",
    "url": "https://github.com/dundee/gdu/releases/download/v{{ version }}/gdu_linux_{{ arch }}.tgz",
    "test": "gdu -v",
    "executable": true,
    "bin": "{{ name }}_linux_{{ arch }}",
    "alias": {
        "arch": {
            "x64": "amd64"
        }
    },
    "extractDirectory": "{{ directorio }}/{{ name }}"
}
