[
    "mkdir -p ~/.local/bin",
    "wget -c -nc https://github.com/dundee/gdu/releases/download/v5.35.0/gdu_linux_amd64.tgz -O ${XDG_CACHE_HOME:-/tmp}/gdu_linux_amd64.tgz",
    "rm -rf ~/.local/src/gdu",
    "mkdir -p ~/.local/src/gdu",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/gdu_linux_amd64.tgz -C ~/.local/src",
    "rm ${XDG_CACHE_HOME:-/tmp}/gdu_linux_amd64.tgz",
    "ln -fs ~/.local/src/gdu/bin/gdu ~/.local/bin/gdu",
    "chmod +x ~/.local/src/gdu/bin/gdu",
    "gdu -v"
]