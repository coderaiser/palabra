[
    "mkdir -p ~/.local/bin",
    "wget -c https://github.com/rayylee/mwget/releases/download/v1.2.0/mwget-linux-arm64.tar.gz -O ${XDG_CACHE_HOME:-/tmp}/mwget-linux-arm64.tar.gz",
    "rm -rf ~/.local/share/mwget",
    "mkdir -p ~/.local/share/mwget",
    "tar xf ${XDG_CACHE_HOME:-/tmp}/mwget-linux-arm64.tar.gz -C ~/.local/share",
    "rm ${XDG_CACHE_HOME:-/tmp}/mwget-linux-arm64.tar.gz",
    "ln -fs ~/.local/share/mwget/mwget ~/.local/bin/mwget",
    "[ -e ~/.local/share/mwget-linux-arm64 ] && rm -rf ~/.local/share/mwget || true",
    "[ -e ~/.local/share/mwget-linux-arm64 ] && mv -f ~/.local/share/mwget-linux-arm64 ~/.local/share/mwget || true",
    "chmod +x ~/.local/share/mwget/mwget",
    "mwget --version"
]