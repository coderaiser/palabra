{
    "name": "nvim",
    "version": "0.12.3",
    "bin": {
        "nvim": "bin/nvim"
    },
    "alias": {
        "arch": {
            "x64": "x86_64"
        }
    },
    "url": "https://github.com/neovim/neovim/releases/download/v{{ version }}/nvim-{{ platform }}-{{ arch }}.tar.gz",
    "rename": "nvim-{{ platform }}-{{ arch }}",
    "test": "nvim -v"
}
