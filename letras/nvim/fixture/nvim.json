[
    "mkdir -p ~/.local/bin",
    "wget -c -nc https://github.com/neovim/neovim/releases/download/v0.12.0/nvim-linux-x86_64.tar.gz -O /tmp/nvim-linux-x86_64.tar.gz",
    "rm -rf ~/.local/src/nvim",
    "mkdir -p ~/.local/src/nvim",
    "tar xf /tmp/nvim-linux-x86_64.tar.gz -C ~/.local/src",
    "rm /tmp/nvim-linux-x86_64.tar.gz",
    "ln -fs ~/.local/src/nvim/bin/nvim ~/.local/bin/nvim",
    "mv ~/.local/src/nvim-linux-x86_64 ~/.local/src/nvim"
]